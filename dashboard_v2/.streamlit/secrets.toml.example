# Template — copy to .streamlit/secrets.toml and fill with real values.
# secrets.toml is gitignored. On Streamlit Cloud, paste the same content
# into App settings -> Secrets.

# Claude API (sentiment analysis, executive briefs, weak signals)
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = "sk-ant-..."

# YouTube Data API v3 (competitor video collector)
# Get a key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY = ""

# Meta Graph API access token (Ad Library collector)
# Get a token at: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN = ""
